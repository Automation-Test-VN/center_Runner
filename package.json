{
  "name": "center-runner",
  "version": "1.0.0",
  "description": "Center Runner web queue and worker for domain-based Playwright jobs.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node --env-file=server.env ./server.mjs",
    "worker": "node --env-file=worker.env ./worker.mjs",
    "worker:once": "node --env-file=worker.env ./worker.mjs --once",
    "worker:dry-run": "node --env-file=worker.env ./worker.mjs --once --dry-run"
  },
  "engines": {
    "node": ">=20"
  }
}
