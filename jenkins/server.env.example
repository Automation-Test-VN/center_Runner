# =============================================================
# SERVER_ENV template
# -------------------------------------------------------------
# Upload the FILLED-IN copy of this file as the Jenkins
# "Secret file" credential with ID: SERVER_ENV
# The pipeline copies it to <CENTER_RUNNER_ROOT>\.env, and both
# start-server.bat (cmd layer) and server.mjs (node --env-file)
# read it. This is the single source of truth for server config.
# Do NOT commit a filled-in copy; keep real values in Jenkins only.
# =============================================================

# Host binding. Keep 0.0.0.0 so LAN / Tailscale machines can reach it.
CENTER_RUNNER_HOST=0.0.0.0
CENTER_RUNNER_PORT=4317

# Playwright test repo on the server machine (reports are served from here).
CENTER_RUNNER_TEST_REPO=D:\workspace\TS_PW_FBC
TEST_REPO_ROOT=D:\workspace\TS_PW_FBC

# Long-poll timeout for waiting workers (ms).
CENTER_RUNNER_WORKER_WAIT_TIMEOUT_MS=60000
