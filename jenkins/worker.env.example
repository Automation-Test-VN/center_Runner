# =============================================================
# WORKER_ENV template
# -------------------------------------------------------------
# Upload the FILLED-IN copy of this file as the Jenkins
# "Secret file" credential with ID: WORKER_ENV
# The pipeline copies it to <CENTER_RUNNER_ROOT>\.env, and both
# start-workers.bat (cmd layer) and worker.mjs (node --env-file)
# read it. This is the single source of truth for worker config.
# Do NOT commit a filled-in copy; keep real values in Jenkins only.
# =============================================================

# --- Center server this worker connects to -------------------
# Use the server's real LAN or Tailscale IP. Never use localhost
# unless the worker runs on the same machine as the server.
CENTER_RUNNER_URL=http://<SERVER_IP>:4317
CENTER_RUNNER_COMMAND_SOURCE=http://<SERVER_IP>:4317/api/jobs/next
CENTER_RUNNER_INTERVAL_MS=5000

# --- This worker machine identity ----------------------------
WORKER_IP=<WORKER_IP>
WORKER_NAME=worker-01
# How many worker processes start-workers.bat launches.
WORKER_COUNT=3

# --- Playwright test repo on this worker machine -------------
TEST_REPO_ROOT=D:\workspace\TS_PW_FBC
CENTER_RUNNER_TEST_REPO=D:\workspace\TS_PW_FBC
