# =============================================================
# SERVER_ENV template
# -------------------------------------------------------------
# Copy this file to server.env and fill in values for your machine.
# This is the single source of truth for server config.
# Do NOT commit a filled-in copy with real credentials.
# =============================================================

# Host binding. Keep 0.0.0.0 so LAN / Tailscale machines can reach it.
CENTER_RUNNER_HOST=0.0.0.0
CENTER_RUNNER_PORT=4317

# Playwright test repo on the server machine (reports are served from here).
CENTER_RUNNER_TEST_REPO=D:\workspace\TS_PW_FBC
TEST_REPO_ROOT=D:\workspace\TS_PW_FBC

# Long-poll timeout for waiting workers (ms).
CENTER_RUNNER_WORKER_WAIT_TIMEOUT_MS=60000
