# =============================================================
# SERVER_ENV template
# -------------------------------------------------------------
# Copy this file to server.env and fill in values for your machine.
# This is the single source of truth for server config.
# Do NOT commit a filled-in copy with real credentials.
# =============================================================

# Host binding. Keep 0.0.0.0 so LAN / Tailscale machines can reach it.
CENTER_RUNNER_HOST=0.0.0.0
CENTER_RUNNER_PORT=4317

# Playwright test repo on the server machine (reports are served from here).
CENTER_RUNNER_TEST_REPO=D:\workspace\TS_PW_FBC
TEST_REPO_ROOT=D:\workspace\TS_PW_FBC

# Long-poll timeout for waiting workers (ms).
CENTER_RUNNER_WORKER_WAIT_TIMEOUT_MS=60000

# A QUEUED job waiting longer than this is marked EXPIRED by the maintenance sweep (e.g. a
# checkAccess ISP with no matching worker online). Default 10 minutes.
CENTER_RUNNER_QUEUE_TTL_MS=600000
# How often the maintenance sweep runs (expire stale queued jobs + prune dead workers). Keep it
# finer than the queue TTL so expiry latency stays small.
CENTER_RUNNER_MAINTENANCE_INTERVAL_MS=60000
# A worker counts as online if it polled within this window (must exceed the long-poll hold time
# so a healthy worker mid-poll is not flagged offline). Default ~2x the 60s poll cycle.
CENTER_RUNNER_WORKER_ONLINE_WINDOW_MS=130000
# Drop a worker from the status roster after it has been silent this long. Default 1 day.
CENTER_RUNNER_WORKER_RETENTION_MS=86400000
